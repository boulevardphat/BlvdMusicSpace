{
  "entities": {
    "Album": {
      "title": "Album",
      "description": "Custom verified details for an album override",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "artist": { "type": "string" },
        "title": { "type": "string" },
        "coverUrl": { "type": "string" },
        "note": { "type": "string" },
        "hex": { "type": "string" },
        "persDesc": { "type": "string" }
      },
      "required": ["id", "artist", "title"]
    },
    "Tier": {
      "title": "Tier",
      "description": "A rank tier in the album ranking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "albums": {
          "type": "array"
        },
        "index": { "type": "integer" }
      },
      "required": ["id", "name", "description", "albums"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "client"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content"]
    }
  },
  "firestore": {
    "albums/{albumId}": {
      "schema": "Album",
      "description": "Stored album covers, descriptions, notes, and custom hex codes"
    },
    "tiers/{tierId}": {
      "schema": "Tier",
      "description": "A rank tier containing album objects"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "A collection of user-model chat messages for assistant curator chat"
    }
  }
}
